---
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  {
    icon: '🏝️',
    numberKey: 'hero.stat.history.number' as const,
    labelKey: 'hero.stat.history.label' as const,
  },
  {
    icon: '🌿',
    numberKey: 'hero.stat.species.number' as const,
    labelKey: 'hero.stat.species.label' as const,
  },
  {
    icon: '🗳️',
    numberKey: 'hero.stat.democracy.number' as const,
    labelKey: 'hero.stat.democracy.label' as const,
  },
  {
    icon: '🔧',
    numberKey: 'hero.stat.chips.number' as const,
    labelKey: 'hero.stat.chips.label' as const,
  },
];
---

<div class="hero-stats">
  {
    stats.map((stat) => (
      <div class="stat">
        <span class="stat-icon">{stat.icon}</span>
        <span class="stat-number">{t(stat.numberKey)}</span>
        <span class="stat-label">{t(stat.labelKey)}</span>
      </div>
    ))
  }
</div>

<style>
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }

  .stat {
    text-align: center;
    padding: 1.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .stat:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .stat-icon {
    display: block;
    font-size: 1.8rem;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .stat-number {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  .stat-label {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .hero-stats {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: 2rem;
    }

    .stat {
      padding: 1rem 0.75rem;
      border-radius: 10px;
      gap: 0.15rem;
    }

    .stat-icon {
      font-size: 1.3rem;
      margin-bottom: 0.1rem;
    }

    .stat-number {
      font-size: 1.5rem;
      margin-bottom: 0.2rem;
    }

    .stat-label {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 380px) {
    .hero-stats {
      gap: 0.5rem;
    }

    .stat {
      padding: 0.8rem 0.5rem;
    }

    .stat-number {
      font-size: 1.3rem;
    }

    .stat-label {
      font-size: 0.75rem;
    }
  }
</style>
