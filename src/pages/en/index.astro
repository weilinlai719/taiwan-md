---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import CoverStory from '../../components/home/CoverStory.astro';
import RandomDiscovery from '../../components/home/RandomDiscovery.astro';
import CategoriesSection from '../../components/home/CategoriesSection.astro';
import RecentUpdates from '../../components/home/RecentUpdates.astro';
import NewsletterSection from '../../components/home/NewsletterSection.astro';
import ContributeSection from '../../components/home/ContributeSection.astro';
import LanguageStatement from '../../components/home/LanguageStatement.astro';
import ReadingPath from '../../components/ReadingPath.astro';
import FeatureCards from '../../components/FeatureCards.astro';
import { fetchRecentCommits } from '../../lib/commits';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';

// Fetch recent commits
const recentCommits = await fetchRecentCommits();

// Build article list for RandomDiscovery
const categories = [
  { id: 'history', name: 'History', folder: 'History' },
  { id: 'geography', name: 'Geography', folder: 'Geography' },
  { id: 'culture', name: 'Culture', folder: 'Culture' },
  { id: 'food', name: 'Food', folder: 'Food' },
  { id: 'art', name: 'Art', folder: 'Art' },
  { id: 'music', name: 'Music', folder: 'Music' },
  { id: 'technology', name: 'Technology', folder: 'Technology' },
  { id: 'nature', name: 'Nature', folder: 'Nature' },
  { id: 'people', name: 'People', folder: 'People' },
  { id: 'society', name: 'Society', folder: 'Society' },
  { id: 'economy', name: 'Economy', folder: 'Economy' },
  { id: 'lifestyle', name: 'Lifestyle', folder: 'Lifestyle' },
];

let allArticles: { title: string; url: string; category: string }[] = [];

for (const cat of categories) {
  try {
    const folderPath = resolve(process.cwd(), 'knowledge', 'en', cat.folder);
    const files = await readdir(folderPath);
    const mdFiles = files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );

    for (const file of mdFiles) {
      const content = await readFile(join(folderPath, file), 'utf-8');
      const { data: frontmatter } = matter(content);
      const slug = basename(file, '.md');
      allArticles.push({
        title: frontmatter.title || slug,
        url: `/en/${cat.id}/${slug}`,
        category: cat.name,
      });
    }
  } catch {
    // folder doesn't exist, skip
  }
}

const randomArticlesData = JSON.stringify(allArticles);

const readingPathSteps = [
  {
    href: '/en/history/democratization',
    title: "Quiet Revolution: Taiwan's Democratization",
    description:
      "From authoritarianism to democracy, Asia's first peaceful transition miracle",
    time: '6 min',
  },
  {
    href: '/en/culture/ethnic-groups',
    title: "Unity in Diversity: Taiwan's Ethnic Groups",
    description:
      "Four major ethnic groups weaving Taiwan's multicultural foundation",
    time: '7 min',
  },
  {
    href: '/en/food/night-market-culture',
    title: 'The Real Taste of Taiwan: Night Market Culture',
    description:
      "World's densest street food social spaces with unmatched warmth",
    time: '5 min',
  },
  {
    href: '/en/technology/semiconductor-industry',
    title: 'Silicon Shield: Semiconductor Industry',
    description: 'How TSMC made a small island the heart of global technology',
    time: '8 min',
  },
  {
    href: '/en/lifestyle/convenience-store-culture',
    title: 'Life Operating System: Convenience Stores',
    description:
      "More than stores - they're the infrastructure of an entire nation",
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: 'Total 30 minutes' },
  { icon: '🎯', label: '5 key domains' },
  { icon: '🌟', label: 'Complete Taiwan overview' },
];
---

<Layout
  title="Open Knowledge Base of Taiwan"
  description="The open-source, AI-friendly knowledge base about Taiwan. 660+ pages covering history, culture, food, music, technology and more — written by the community, for the world."
  lang="en"
>
  <HeroSection />

  <CoverStory />

  <FeatureCards
    lang="en"
    sectionTitle="Why Taiwan.md?"
    cards={[
      {
        icon: '🎯',
        title: 'Curated Perspectives',
        description:
          'Carefully curated deep narratives, not encyclopedic listings',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly Design',
        description:
          "Structured content that helps AI understand Taiwan's complexity",
      },
      {
        icon: '🌍',
        title: 'Bilingual Global Vision',
        description:
          "Starting from local perspectives, telling Taiwan's story in global languages",
      },
      {
        icon: '📚',
        title: 'Complete Multi-dimensional',
        description:
          "Covering 12+ domains, presenting Taiwan's three-dimensional complete picture",
      },
    ]}
  />

  <RandomDiscovery articlesJson={randomArticlesData} />

  <ReadingPath
    lang="en"
    title="📖 Don't know where to start?"
    subtitle="Discover the real Taiwan in 30 minutes with these 5 essential articles"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="Continue exploring more topics →"
  />

  <LanguageStatement />

  <CategoriesSection>
    <Fragment slot="prose">
      <p>
        This island spans just 36,000 square kilometers, yet contains a
        microcosm of the entire world. From the 3,952-meter peak of Yushan to
        the abyssal trenches of the Pacific Ocean,
        <a href="/en/geography" class="topic-pill">🗺️ the geography here</a> is a
        live broadcast of mountain-building in action- tectonic compression, volcanic
        eruptions, fault movements in an unceasing geological symphony that has played
        for four million years, creating this youngest and most dynamic beautiful
        island on Earth.
      </p>

      <p>
        Four hundred years ago, the Dutch built Fort Zeelandia in Tainan. Since
        then, every ruler- the Zheng Kingdom, the Qing Empire, Japan, the
        Republic of China-has carved their own inscriptions on this island. But
        what truly makes Taiwan Taiwan is that <a
          href="/en/history"
          class="topic-pill">📜 long awakening</a
        > from authoritarianism to democracy. From the blood and tears of February
        28th to the cheers of martial law's end, from Formosa to Sunflower, every
        moment of pain and resistance has made this island's soul clearer.
      </p>

      <p>
        Multiple bloodlines flow through this land. Indigenous peoples have
        lived here for six thousand years. Hoklo people from Fujian arrived in
        the 17th century, followed by Hakka communities, mainlanders who
        migrated from various Chinese provinces after the war, and recent new
        residents and migrant workers. Each group brought their own languages,
        beliefs, and memories.
        <a href="/en/culture" class="topic-pill">🎭 Taiwan's culture</a> is not a
        melting pot, but a puzzle- each piece maintaining its own color and shape,
        assembled into an unprecedented picture.
      </p>

      <p>
        Walk into any Taiwan night market, and you'll simultaneously smell Hoklo
        oyster omelets, Japanese tempura, and the Shandong scallion pancakes
        brought by post-war veterans.
        <a href="/en/food" class="topic-pill">🍜 This island's flavors</a>
        are the gustatory version of its immigration history. From street vendors'
        human warmth to Michelin restaurants' precision, Taiwanese people tell stories
        through food, preserve memories through cuisine.
      </p>

      <p>
        The Butterfly Kingdom is not a romantic metaphor, but an ecological
        reality. On an island smaller than the Netherlands, more than 59,000
        species crowd together — an extraordinary 2.5% of global biodiversity on
        just 0.025% of the world's land area.
        <a href="/en/nature" class="topic-pill">🌿 Taiwan's nature</a> is a three-dimensional
        evolutionary textbook: from tropical rainforests to alpine tundra, from coral
        reefs to the Kuroshio Current, species evolve, diverge, and coexist here.
        But the price of industrial development is also written in the mountains and
        rivers, as the tug-of-war between conservation and development continues.
      </p>

      <p>
        From Lai He and Yang Kui to Pai Hsien-yung and Chu T'ien-hsin, from the
        Wufeng Lin family to the Koo Chen-fu clan,
        <a href="/en/people" class="topic-pill">👥 Taiwan's figures</a> are microcosms
        of their times. They are not just individual biographies, but collective memories
        of how this island survived in the cracks and found hope in hardship. Behind
        every story are the resilience and choices of small people in great times.
      </p>

      <p>
        From temple fair Eight Generals to contemporary art at the Venice
        Biennale,
        <a href="/en/art" class="topic-pill">🎨 Taiwan's art</a> is a dialogue between
        tradition and innovation. Jiaozhi pottery and digital installations, traditional
        opera and experimental theater, indigenous totems and contemporary painting-artists
        constantly ask: How do we respond to this era through creation? How do we
        maintain locality in globalization?
      </p>

      <p>
        From indigenous ancient songs to Deng Yu-xian's "Longing for Spring
        Wind," from campus folk songs to the Golden Melody Awards,
        <a href="/en/music" class="topic-pill">🎵 Taiwan's sounds</a> are the island's
        heartbeat. Music transcends ethnic, linguistic, and generational boundaries,
        becoming the most cohesive carrier of collective memory. Whether it's Mayday's
        roar at the Taipei Arena or indigenous ancient songs in tribal communities,
        they all tell the same story: who we are, where we come from.
      </p>

      <p>
        TSMC's wafers are not just silicon chips, but proof of Taiwan's position
        in the global technology map.
        <a href="/en/technology" class="topic-pill">💻 This tech island</a> has evolved
        from contract manufacturing to innovative R&D, from hardware advantages to
        software breakthroughs. But technological development also brings challenges:
        digital divides, AI displacement, cybersecurity threats-how does Taiwan surf
        the tech wave without drowning?
      </p>

      <p>
        From Asia's Four Little Dragons to the semiconductor empire,
        <a href="/en/economy" class="topic-pill">📈 Taiwan's economic miracle</a
        >
        is a textbook case of small nation, big strategy. But behind the miracle are
        countless overtime nights, meticulous cost control, and relentless pursuit
        of efficiency. Now facing the US-China trade war and global supply chain restructuring,
        how does Taiwan continue writing its economic legend?
      </p>

      <p>
        <a href="/en/society" class="topic-pill">⚖️ Taiwan's society</a>'s
        keywords are "diversity" and "inclusion." From Asia's first legalization
        of same-sex marriage to the ongoing promotion of transitional justice,
        from nuclear referendum to pension reform, Taiwanese people are learning
        how to dialogue amid differences and seek consensus in conflict. This is
        democracy's practice ground and the future's laboratory.
      </p>

      <p>
        Taiwanese people's <a href="/en/lifestyle" class="topic-pill"
          >🏠 lifestyle</a
        > is a blend of convenience and human warmth. The world's highest density
        of convenience stores, yet night markets' warmth remains unique. In the 24/7
        urban rhythm, neighborhood greetings and care are still preserved. In globalization's
        torrent, how do Taiwanese people maintain their life philosophy? The answer
        might lie in that daily greeting: "Have you eaten yet?"
      </p>
    </Fragment>
  </CategoriesSection>

  <RecentUpdates commits={recentCommits} />

  <NewsletterSection />

  <ContributeSection />
</Layout>

<style>
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    color: #1a1a2e;
    margin-bottom: 1rem;
  }
</style>
