---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoriesSection from '../components/home/CategoriesSection.astro';
import LanguageStatement from '../components/home/LanguageStatement.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import NewsletterSection from '../components/home/NewsletterSection.astro';
import CommunityFeedback from '../components/home/CommunityFeedback.astro';
import ContributeSection from '../components/home/ContributeSection.astro';
import ProticoScript from '../components/ProticoScript.astro';
import { fetchRecentCommits } from '../lib/commits';
import { feedbacks } from '../data/feedbacks';

const recentCommits = await fetchRecentCommits();

const readingPathSteps = [
  {
    href: '/history/民主化',
    title: '寧靜革命：台灣民主化',
    description: '從威權到民主，亞洲第一的和平轉型奇蹟',
    time: '6 min',
  },
  {
    href: '/culture/族群（閩南客家原住民外省新住民）',
    title: '多元一體：台灣族群',
    description: '四大族群共同編織的多彩文化基底',
    time: '7 min',
  },
  {
    href: '/food/夜市文化',
    title: '最真實的台灣味：夜市文化',
    description: '密度世界第一的庶民美食社交空間',
    time: '5 min',
  },
  {
    href: '/technology/半導體產業',
    title: '護國神山：半導體產業',
    description: '台積電如何讓小島成為全球科技心臟',
    time: '8 min',
  },
  {
    href: '/lifestyle/便利商店文化',
    title: '生活作業系統：便利商店',
    description: '不只是商店，而是整個國家的基礎建設',
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: '總計 30 分鐘' },
  { icon: '🎯', label: '跨越 5 大領域' },
  { icon: '🌟', label: '完整認識台灣' },
];
---

<Layout
  title="開源台灣知識庫"
  description="開源、AI-friendly 的台灣完整知識庫。660+ 頁深度內容涵蓋歷史、文化、美食、音樂、科技等 12 大主題，由社群共同編撰，讓全世界認識真正的台灣。"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery />

  <ReadingPath
    title="📖 不知道從哪開始？"
    subtitle="用這 5 篇文章，在 30 分鐘內認識真正的台灣"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="繼續探索更多主題 →"
  />

  <FeatureCards
    lang="zh-TW"
    sectionTitle="為什麼需要 Taiwan.md？"
    cards={[
      {
        icon: '🎯',
        title: '策展式觀點',
        description: '精心策展的深度敘事，不是百科全書式羅列',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly 設計',
        description: '結構化內容，讓AI也能理解台灣的複雜性',
      },
      {
        icon: '🌍',
        title: '雙語國際視野',
        description: '從在地觀點出發，用國際語言說台灣故事',
      },
      {
        icon: '📚',
        title: '完整多面向',
        description: '涵蓋12+領域，呈現台灣的立體完整面貌',
      },
    ]}
  >
    <div class="features-cta">
      <a href="/graph" class="feature-btn">🔗 知識圖譜 — 探索文章之間的連結</a>
      <a
        href="https://github.com/frank890417/taiwan-md/tree/main/knowledge"
        target="_blank"
        rel="noopener noreferrer"
        class="feature-btn secondary">📂 瀏覽 SSOT 原始資料 ↗</a
      >
    </div>
  </FeatureCards>

  <section class="mini-graph-section">
    <a href="/graph" class="mini-graph-link">
      <div class="mini-graph-text">
        <h3>🕸️ 知識圖譜</h3>
        <p>每篇文章都不是孤島——點擊探索台灣知識的連結網絡</p>
      </div>
      <div id="mini-graph" class="mini-graph-container"></div>
    </a>
  </section>

  <CategoriesSection>
    <Fragment slot="prose">
      <p>
        這座島嶼只有 36,000 平方公里，卻裝進了整個世界的縮影。 從 3,952
        公尺的玉山之巔到太平洋的深海溝壑，
        <a href="/geography" class="topic-pill">🗺️ 這裡的地理</a
        >本身就是一場造山運動的現場直播——
        板塊擠壓、火山噴發、斷層錯動，四百萬年來不停歇的地質交響曲，
        造就了這座世界上最年輕也最動盪的美麗島嶼。
      </p>

      <p>
        四百年前，荷蘭人在台南築起了熱蘭遮城。此後的每一個統治者——
        鄭氏、清帝國、日本、國民黨——都在這座島上刻下了自己的銘文。
        但真正讓台灣成為台灣的，是那段從威權到民主的<a
          href="/history"
          class="topic-pill">📜 漫長覺醒</a
        >。 從二二八的血淚到解嚴的歡呼，從美麗島到太陽花，
        每一次的痛苦與反抗，都讓這座島的靈魂更加清晰。
      </p>

      <p>
        這片土地上流淌著多重血液。原住民族在此安居了六千年，
        十七世紀後陸續到來的閩南人、客家人，戰後從大陸各省遷徙而來的外省族群，
        近年的新住民與移工，每一群人都帶來了自己的語言、信仰與記憶。
        <a href="/culture" class="topic-pill">🎭 台灣的文化</a
        >不是熔爐，而是拼圖——
        每一塊都保持著自己的顏色與形狀，拼湊出一幅前所未有的圖像。
      </p>

      <p>
        走進任何一座台灣的夜市，你會同時聞到閩南的蚵仔煎、日本的天婦羅、
        和戰後老兵帶來的山東蔥油餅。<a href="/food" class="topic-pill"
          >🍜 這座島的味道</a
        >， 就是它的移民史的味覺版本。從路邊攤的人情味到米其林餐廳的精工細作，
        台灣人用食物說故事，用料理保存記憶。
      </p>

      <p>
        蝴蝶王國不是浪漫的比喻，而是生態現實。在這個比荷蘭還小的島嶼上，
        擠進了超過五萬九千種生物——佔全球物種數量的百分之二點五。
        <a href="/nature" class="topic-pill">🌿 台灣的自然</a
        >是一部立體的演化史書：
        從熱帶雨林到高山寒原，從珊瑚礁到黑潮，物種在此演化、分化、共存。
        但工業發展的代價也寫在山川裡，環保與開發的拉扯仍在進行。
      </p>

      <p>
        從賴和、楊逵到白先勇、朱天心，從霧峰林家到辜振甫家族，
        <a href="/people" class="topic-pill">👥 台灣的人物</a>是時代的縮影。
        他們不只是個人的傳記，更是這座島嶼如何在夾縫中求生存、
        在困頓中找希望的集體記憶。每一個故事背後，
        都是大時代下小人物的堅韌與選擇。
      </p>

      <p>
        從廟會的八家將到當代藝術的威尼斯雙年展，
        <a href="/art" class="topic-pill">🎨 台灣的藝術</a>是傳統與創新的對話。
        交趾陶與數位裝置、傳統戲曲與實驗劇場、
        原住民圖騰與當代繪畫——藝術家們不斷在問：
        我們如何用創作回應這個時代？如何在全球化中保持在地性？
      </p>

      <p>
        從原住民的古調到鄧雨賢的〈望春風〉，從校園民歌到金曲獎，
        <a href="/music" class="topic-pill">🎵 台灣的聲音</a>是島嶼的心跳。
        音樂跨越了族群、語言、世代的界線，成為最能凝聚共同記憶的載體。
        無論是五月天在小巨蛋的吶喊，還是原住民在部落裡的古謠，
        都在述說著同一個故事：我們是誰，我們來自哪裡。
      </p>

      <p>
        台積電的晶圓不只是矽片，而是台灣在全球科技版圖上的定位證明。
        <a href="/technology" class="topic-pill">💻 這座科技島</a
        >從代工製造走向創新研發，
        從硬體優勢邁向軟體突破。但科技發展也帶來了挑戰： 數位落差、AI
        取代、資安威脅——台灣如何在科技浪潮中既衝浪又不被淹沒？
      </p>

      <p>
        從亞洲四小龍到半導體帝國，<a href="/economy" class="topic-pill"
          >📈 台灣的經濟奇蹟</a
        >
        是小國大戰略的典型案例。但奇蹟背後是無數個加班的夜晚、 斤斤計較的成本控制、永不停歇的效率追求。
        如今面對中美貿易戰、全球供應鏈重組，台灣如何繼續寫下經濟傳奇？
      </p>

      <p>
        <a href="/society" class="topic-pill">⚖️ 台灣社會</a
        >的關鍵字是「多元」與「包容」。
        從亞洲第一個同性婚姻合法化，到轉型正義的持續推動，
        從核四公投到年金改革，台灣人正在學習如何在分歧中對話，
        在衝突中尋找共識。這是民主的練習場，也是未來的實驗室。
      </p>

      <p>
        台灣人的<a href="/lifestyle" class="topic-pill">🏠 生活方式</a
        >是便利與人情的混合體。 便利商店的密度世界第一，夜市的溫度卻是獨一無二。
        24 小時不打烊的城市節奏裡，依然保留著鄰里的問候與照顧。
        在全球化的洪流中，台灣人如何保持自己的生活哲學？
        答案或許就在那一句「你吃飽了嗎？」的日常問候裡。
      </p>
    </Fragment>
  </CategoriesSection>

  <LanguageStatement />

  <RecentUpdates commits={recentCommits} />

  <NewsletterSection />

  <CommunityFeedback feedbacks={feedbacks} />

  <ContributeSection />
</Layout>

<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('mini-graph');
    if (container) {
      const categories = [
        { id: 'history', name: '歷史', color: '#dc2626' },
        { id: 'geography', name: '地理', color: '#2563eb' },
        { id: 'culture', name: '文化', color: '#7c3aed' },
        { id: 'food', name: '美食', color: '#ea580c' },
        { id: 'art', name: '藝術', color: '#db2777' },
        { id: 'music', name: '音樂', color: '#4f46e5' },
        { id: 'technology', name: '科技', color: '#0891b2' },
        { id: 'nature', name: '自然', color: '#16a34a' },
        { id: 'people', name: '人物', color: '#ca8a04' },
        { id: 'society', name: '社會', color: '#64748b' },
        { id: 'economy', name: '經濟', color: '#0d9488' },
        { id: 'lifestyle', name: '生活', color: '#f97316' },
      ];

      const nodes = [
        {
          id: 'taiwan',
          name: 'Taiwan.md',
          size: 18,
          color: '#2d5016',
          group: 'core',
        },
        ...categories.map((c) => ({
          id: c.id,
          name: c.name,
          size: 12,
          color: c.color,
          group: 'category',
        })),
      ];

      const edges = categories.map((c) => ({ source: 'taiwan', target: c.id }));
      const crossLinks = [
        ['history', 'people'],
        ['history', 'society'],
        ['culture', 'art'],
        ['culture', 'music'],
        ['food', 'lifestyle'],
        ['technology', 'economy'],
        ['nature', 'geography'],
        ['people', 'art'],
        ['society', 'economy'],
        ['music', 'culture'],
        ['lifestyle', 'food'],
        ['geography', 'nature'],
      ];
      crossLinks.forEach(([source, target]) => edges.push({ source, target }));

      const width = container.clientWidth;
      const height = 300;

      const svg = d3
        .select('#mini-graph')
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('preserveAspectRatio', 'xMidYMid meet');

      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(edges)
            .id((d) => d.id)
            .distance(60),
        )
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force(
          'collision',
          d3.forceCollide().radius((d) => d.size + 4),
        );

      const link = svg
        .append('g')
        .selectAll('line')
        .data(edges)
        .join('line')
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.5);

      const node = svg
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => d.size)
        .attr('fill', (d) => d.color)
        .attr('fill-opacity', 0.85)
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);

      const label = svg
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.name)
        .attr('text-anchor', 'middle')
        .attr('dy', (d) => d.size + 14)
        .attr('font-size', (d) => (d.group === 'core' ? '11px' : '9px'))
        .attr('font-weight', (d) => (d.group === 'core' ? '700' : '500'))
        .attr('fill', '#374151')
        .attr('pointer-events', 'none');

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }
  });
</script>

<!-- Protico Community Chat Bubble — sponsored by Howie Young -->
<ProticoScript />

<style>
