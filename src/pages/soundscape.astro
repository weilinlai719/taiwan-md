---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url) || 'zh-TW';
const t = useTranslations(lang);

const categories = [
  {
    id: 'urban',
    icon: '🏙️',
    title: '都市日常的聲音密碼',
    titleEn: 'Urban Soundscape',
    sounds: [
      {
        file: 'taipei-nangang-garbage-truck-melody-maidens-prayer.mp3',
        location: '台北南港',
        locationEn: 'Taipei Nangang',
        description: '垃圾車音樂（少女的祈禱）',
        descriptionEn: "Garbage truck melody (Maiden's Prayer)",
        contributor: 'x1001000',
        date: '2021-03',
        icon: '🚛',
      },
      {
        file: 'new-taipei-banqiao-garbage-truck-melody-fur-elise.mp3',
        location: '新北板橋',
        locationEn: 'New Taipei Banqiao',
        description: '垃圾車音樂（給愛麗絲）',
        descriptionEn: 'Garbage truck melody (Für Elise)',
        contributor: 'yuweichen1008',
        date: '2026-03',
        icon: '🚛',
      },
    ],
    wishlist: [
      {
        icon: '🚛',
        text: '各縣市垃圾車音樂',
        textEn: 'Garbage truck melodies (regional variations)',
      },
      {
        icon: '🛵',
        text: '紅燈轉綠的機車起步聲',
        textEn: 'Scooter swarm at green light',
      },
      { icon: '📢', text: '選舉宣傳車', textEn: 'Election campaign trucks' },
      { icon: '🚂', text: '火車進站音樂', textEn: 'Train station jingles' },
      {
        icon: '🏪',
        text: '便利商店門鈴聲',
        textEn: 'Convenience store door chimes',
