    id: 'sacred',
    icon: '🏯',
    title: '神聖的聲音：廟會與宗教',
    titleEn: 'Sacred Sounds: Temples & Religion',
    sounds: [],
    wishlist: [
      {
        icon: '🥁',
        text: '北管鑼鼓——廟口的搖滾樂',
        textEn: 'Beiguan drums — temple rock & roll',
      },
