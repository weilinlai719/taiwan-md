        icon: '🎶',
        text: '南管——東方最古老的室內樂',
        textEn: 'Nanguan — oldest chamber music of the East',
      },
      {
        icon: '💃',
        text: '電子花車——神聖與世俗的碰撞',
        textEn: 'Electronic flower car — sacred meets profane',
      },
      {
        icon: '🪘',
        text: '媽祖遶境鑼鼓陣',
        textEn: 'Mazu pilgrimage drum procession',
      },
      {
        icon: '📿',
        text: '寺廟早課木魚誦經',
        textEn: 'Temple morning chanting',
      },
    ],
    article: '/music/台灣聲音地景',
  },
  {
    id: 'indigenous',
    icon: '🏔️',
    title: '原住民的聲音：大地的記憶',
    titleEn: 'Indigenous Voices: Memory of the Land',
    sounds: [],
    wishlist: [
      {
        icon: '🎵',
        text: '布農族 Pasibutbut（祈禱小米豐收歌）',
        textEn: 'Bunun Pasibutbut (Millet Prayer Song)',
      },
      {
        icon: '🌾',
        text: '阿美族豐年祭歌舞',
        textEn: 'Amis Ilisin harvest festival songs',
      },
      {
        icon: '🎺',
        text: '排灣族雙管鼻笛',
        textEn: 'Paiwan double-tube nose flute',
      },
      {
        icon: '🌊',
        text: '達悟族拍手歌',
        textEn: 'Tao hand-clapping songs (Orchid Island)',
      },
    ],
    article: '/music/台灣聲音地景',
  },
  {
    id: 'nature',
    icon: '🌿',
    title: '自然的聲音',
    titleEn: 'Sounds of Nature',
    sounds: [
      {
        file: 'taichung-green-museumbrary-crickets.mp3',
        location: '台中綠美圖',
        locationEn: 'Taichung Green Museumbrary',
        description: '夜晚蟋蟀聲',
        descriptionEn: 'Evening cricket chorus',
        contributor: 'bugnimusic',
        date: '2026-03',
        icon: '🦗',
      },
      {
        file: 'fugui-cape-ocean-waves.mp3',
        location: '新北石門・富貴角公園步道',
        locationEn: 'Fugui Cape Trail, Shimen, New Taipei',
        description: '海浪拍打岩岸',
        descriptionEn: 'Ocean waves crashing on rocky shore',
        contributor: 'Perry Su',
        date: '2026-03',
        icon: '🌊',
      },
      {
        file: 'fugui-cape-birds-insects.mp3',
        location: '新北石門・富貴角公園步道',
