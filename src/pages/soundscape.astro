        location: '新北石門・二坪頂登山步道',
        locationEn: 'Erpingding Trail, Shimen, New Taipei',
        description: '山徑鳥鳴與蟲聲',
        descriptionEn: 'Birds and insects on mountain trail',
        contributor: 'Perry Su',
        date: '2026-03',
        icon: '🐦',
      },
    ],
    wishlist: [
      { icon: '🌊', text: '東海岸浪聲', textEn: 'East coast waves' },
      { icon: '🐦', text: '山林鳥鳴', textEn: 'Mountain birdsong' },
      { icon: '🦗', text: '各地蟲鳴', textEn: 'Insect choruses across Taiwan' },
      {
        icon: '⛈️',
        text: '春雷與梅雨',
        textEn: 'Spring thunder and plum rain',
      },
      {
        icon: '🐸',
        text: '台灣特有種蛙鳴',
        textEn: 'Taiwan endemic frog calls',
      },
    ],
    article: '/music/台灣聲音地景',
  },
  {
    id: 'vanishing',
    icon: '⏳',
    title: '正在消失的聲音',
    titleEn: 'Vanishing Sounds',
    sounds: [],
    wishlist: [
      {
        icon: '🔪',
        text: '磨刀師傅的喇叭聲',
        textEn: "Knife sharpener's horn",
      },
      {
        icon: '📻',
        text: '五金行的叫賣廣播',
        textEn: 'Hardware store PA announcements',
      },
      {
        icon: '🗣️',
        text: '台語的聲調變化',
        textEn: 'Taiwanese Hokkien tonal variations',
      },
      {
        icon: '🍧',
        text: '叭噗冰淇淋叫賣',
        textEn: 'Traditional ice cream vendor horn',
      },
    ],
    article: '/music/台灣聲音地景',
  },
];

const totalSounds = categories.reduce((sum, cat) => sum + cat.sounds.length, 0);
const totalWishlist = categories.reduce(
  (sum, cat) => sum + cat.wishlist.length,
  0,
);
---

<Layout
  title="台灣聲景 Taiwan Soundscape — Taiwan.md"
  description="用耳朵認識台灣——田野錄音收集計畫，收錄蟋蟀、垃圾車、廟會、浪聲等台灣獨有的聲音風景"
>
  <div class="soundscape-page">
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-kicker">🎧 Soundscape</p>
        <h1>台灣聲景</h1>
        <p class="hero-subtitle">
          有些故事，用耳朵聽比用眼睛看更真實。<br />
          <span class="hero-subtitle-en"
            >Some stories are best told through ears.</span
          >
        </p>
        <p class="hero-count">
          {totalSounds} recordings · {totalWishlist} wanted · 5 categories
        </p>
        <p class="hero-article">
          📖 深度文章：<a href="/music/台灣聲音地景">台灣聲音地景</a>
        </p>
      </div>
    </section>

    {
      categories.map((cat) => (
        <section class="category-section" id={cat.id}>
          <div class="section-inner">
            <h2>
              <span class="cat-icon">{cat.icon}</span>
              {cat.title}
              <span class="section-label">{cat.titleEn}</span>
            </h2>

            {cat.sounds.length > 0 && (
              <div class="sound-grid">
                {cat.sounds.map((sound) => (
                  <div class="sound-card">
                    <div class="sound-header">
                      <span class="sound-icon">{sound.icon}</span>
                      <div>
                        <h3>
                          {sound.location}{' '}
                          <span class="sound-location-en">
                            {sound.locationEn}
                          </span>
                        </h3>
                      </div>
                    </div>
                    <p class="sound-desc">
                      {sound.description}{' '}
                      <span class="sound-desc-en">{sound.descriptionEn}</span>
                    </p>
                    <div class="sound-meta">
                      <a
                        href={`https://github.com/${sound.contributor}`}
                        target="_blank"
                        rel="noopener"
                        class="contributor"
                      >
                        @{sound.contributor}
                      </a>
                      <span class="sound-date">{sound.date}</span>
                    </div>
                    <audio controls preload="none" class="sound-player">
                      <source
                        src={`/assets/sounds/${sound.file}`}
                        type="audio/mpeg"
                      />
                    </audio>
                  </div>
                ))}
              </div>
            )}

            {cat.sounds.length === 0 && (
              <div class="empty-state">
                <p>這個分類還沒有錄音，等你來貢獻！</p>
                <p class="empty-en">
                  No recordings yet — be the first contributor!
                </p>
              </div>
            )}

            <div class="wishlist-inline">
              <h4>📋 想收集 Wanted</h4>
              <div class="wishlist-grid">
                {cat.wishlist.map((item) => (
                  <div class="wishlist-card">
                    <span class="wishlist-icon">{item.icon}</span>
                    <div>
                      <p class="wishlist-text">{item.text}</p>
                      <p class="wishlist-text-en">{item.textEn}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <a href={cat.article} class="read-more">
              📖 閱讀完整聲音故事 Read more →
            </a>
          </div>
        </section>
      ))
    }

    <section class="contribute-cta">
      <div class="section-inner">
        <h2>🎤 貢獻你的錄音</h2>
        <p>
          用手機錄下 30 秒到 2 分鐘的台灣聲景，轉成 MP3，開一個 PR 就好。<br />
          不會用 GitHub？直接<a href="mailto:cheyu.wu@monoame.com">寄信給我們</a
          >，附上錄音檔和地點描述。
        </p>
        <div class="cta-steps">
          <div class="step">
            <span class="step-num">1</span> 錄下聲音（30s – 2min）
          </div>
          <div class="step">
            <span class="step-num">2</span> 轉成 MP3（128kbps+）
          </div>
          <div class="step">
            <span class="step-num">3</span> 開 PR 或寄信給我們
          </div>
        </div>
        <a href="/contribute" class="cta-btn">前往貢獻頁面 →</a>
      </div>
    </section>
  </div>
</Layout>

<style>
  .soundscape-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
    margin-bottom: 3rem;
  }
  .hero-kicker {
    font-size: 0.9rem;
    color: #065f46;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .hero h1 {
    font-family: var(--font-title, 'Noto Serif TC', serif);
    font-size: 3.5rem;
    font-weight: 900;
    margin: 0.3rem 0;
    color: #1a3c34;
    letter-spacing: -0.02em;
  }
  .hero-subtitle {
    font-size: 1.3rem;
    color: #64748b;
    line-height: 1.7;
    margin-top: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-subtitle-en {
    font-size: 0.95rem;
    color: #64748b;
    font-style: italic;
  }
  .hero-count {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: #64748b;
    letter-spacing: 0.1em;
  }
  .hero-article {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }
  .hero-article a {
    color: #3b82f6;
    text-decoration: none;
    border-bottom: 1px dashed rgba(59, 130, 246, 0.4);
  }
  .hero-article a:hover {
    border-bottom-style: solid;
  }

  .category-section {
    margin-bottom: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid #e2e8f0;
  }
  .category-section:last-of-type {
    border-bottom: none;
  }

  .section-inner {
    margin-bottom: 1rem;
  }
  .section-inner h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cat-icon {
    font-size: 1.3rem;
  }
  .section-label {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 400;
  }

  .sound-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .sound-card {
    background: #f8fafc;
    border: 2px solid #cbd5e1;
    border-radius: 10px;
    padding: 0.9rem 1rem;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .sound-card:hover {
    border-color: #3b82f6;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.12);
  }
  .sound-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sound-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
  }
  .sound-info h3 {
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.3;
  }
  .sound-location-en {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
  }
  .sound-desc {
    color: #334155;
    font-size: 0.85rem;
    margin: 0;
  }
  .sound-desc-en {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
  }
  .sound-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.75rem;
  }
  .contributor {
    color: #3b82f6;
    text-decoration: none;
  }
  .contributor:hover {
    text-decoration: underline;
  }
  .sound-date {
    color: #64748b;
  }
  .sound-player {
    width: 100%;
    height: 36px;
    border-radius: 6px;
  }

  .empty-state {
    background: #f8fafc;
    border: 2px dashed #94a3b8;
    border-radius: 10px;
    padding: 1.5rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .empty-state p {
    color: #64748b;
    margin: 0;
  }
  .empty-en {
    font-size: 0.85rem;
    margin-top: 0.3rem !important;
    font-style: italic;
  }

  .wishlist-inline {
    margin-bottom: 1rem;
  }
  .wishlist-inline h4 {
    font-size: 1rem;
    color: #334155;
    font-weight: 600;
    margin-bottom: 0.8rem;
  }
  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.6rem;
  }
  .wishlist-card {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    background: #f8fafc;
    border: 2px solid #cbd5e1;
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
  }
  .wishlist-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .wishlist-text {
    margin: 0;
    color: #1a1a2e;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .wishlist-text-en {
    margin: 0.15rem 0 0;
    font-size: 0.78rem;
    color: #475569;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.5rem;
    color: #3b82f6;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .read-more:hover {
    color: #2563eb;
  }

  .contribute-cta {
    text-align: center;
    padding: 2rem 0;
  }
  .contribute-cta p {
    color: #475569;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .contribute-cta a:not(.cta-btn) {
    color: #3b82f6;
  }
  .cta-steps {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .step {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #334155;
    font-size: 0.95rem;
  }
  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .cta-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 8px;
    color: #3b82f6;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .cta-btn:hover {
    background: rgba(59, 130, 246, 0.15);
    border-color: rgba(59, 130, 246, 0.5);
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2rem;
    }
    .cta-steps {
      flex-direction: column;
      align-items: center;
    }
    .wishlist-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
