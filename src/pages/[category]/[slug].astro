---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const categories = [
  'history', 'geography', 'culture', 'food', 'art', 'music',
  'technology', 'nature', 'people', 'society', 'economy', 'lifestyle'
];

export async function getStaticPaths() {
  const paths: any[] = [];
  
  for (const cat of ['history', 'geography', 'culture', 'food', 'art', 'music',
    'technology', 'nature', 'people', 'society', 'economy', 'lifestyle']) {
    try {
      const articles = await getCollection(`zh-tw-${cat}` as any);
      for (const article of articles) {
        if (!article.id.startsWith('_')) {
          paths.push({
            params: { category: cat, slug: article.id },
            props: { article },
          });
        }
      }
    } catch (e) {
      // skip
    }
  }
  
  return paths;
}

const { article } = Astro.props;
const { category } = Astro.params;
const { Content } = await render(article);

const categoryNames: Record<string, string> = {
  history: '📜 歷史', geography: '🗺️ 地理', culture: '🎭 文化',
  food: '🍜 美食', art: '🎨 藝術', music: '🎵 音樂',
  technology: '💻 科技', nature: '🌿 自然', people: '👥 人物',
  society: '⚖️ 社會', economy: '📈 經濟', lifestyle: '🏠 生活',
};
---

<Layout title={`${article.data.title} — Taiwan.md`}>
  <main class="article-page">
    <div class="breadcrumb">
      <a href="/">首頁</a> / <a href={`/${category}`}>{categoryNames[category!] || category}</a>
    </div>
    
    <article>
      <header>
        <h1>{article.data.title}</h1>
        {article.data.description && (
          <p class="description">{article.data.description}</p>
        )}
        <div class="meta">
          {article.data.readingTime && <span>⏱ {article.data.readingTime} 分鐘閱讀</span>}
          {article.data.tags && article.data.tags.length > 0 && (
            <span class="tags">
              {article.data.tags.map((tag: string) => <span class="tag">#{tag}</span>)}
            </span>
          )}
        </div>
      </header>
      
      <div class="content">
        <Content />
      </div>
    </article>
    
    <div class="back-link">
      <a href={`/${category}`}>← 回到{categoryNames[category!] || category}</a>
    </div>
  </main>
</Layout>

<style>
  .article-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  .breadcrumb {
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: #64748b;
  }
  .breadcrumb a {
    color: #3b82f6;
    text-decoration: none;
  }
  article header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e2e8f0;
  }
  article h1 {
    font-size: 2.2rem;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .description {
    font-size: 1.1rem;
    color: #64748b;
    line-height: 1.6;
  }
  .meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: #94a3b8;
    margin-top: 0.5rem;
  }
  .tag {
    background: #f1f5f9;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-left: 0.25rem;
  }
  .content {
    line-height: 1.8;
    color: #334155;
  }
  .content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #1a1a2e;
  }
  .content :global(h3) {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #334155;
  }
  .content :global(a) {
    color: #3b82f6;
  }
  .content :global(blockquote) {
    border-left: 3px solid #3b82f6;
    padding-left: 1rem;
    color: #64748b;
    margin: 1.5rem 0;
  }
  .content :global(ul), .content :global(ol) {
    padding-left: 1.5rem;
  }
  .content :global(li) {
    margin-bottom: 0.5rem;
  }
  .back-link {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
  }
  .back-link a {
    color: #3b82f6;
    text-decoration: none;
  }
</style>
